            ServerPlayer player = context.getSender();
            if (player != null && player.getItemBySlot(EquipmentSlot.HEAD).getItem() instanceof ShulkerHelmetItem) {
                //ShulkerHelmetItem.activateLevitationAbility(player);

            }

        });
        context.setPacketHandled(true);
    }
    private static void spawnParticles(Player player) {
        Level level = player.level();
        double centerX = player.getX();
        double centerY = player.getY();
        double centerZ = player.getZ();
        double radius = 2.0; // Promień okręgu (średnica 2 bloki)
        int particleCount = 20; // Liczba cząsteczek do wygenerowania okręgu

        for (int i = 0; i < particleCount; i++) {
            double angle = 2 * Math.PI * i / particleCount;
            double xOffset = Math.cos(angle) * radius;
            double zOffset = Math.sin(angle) * radius;
            level.addParticle(ParticleTypes.END_ROD, centerX + xOffset, centerY, centerZ + zOffset, 0, 0, 0);
        }
    }
}
